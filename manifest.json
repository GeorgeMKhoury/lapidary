{
  "manifest_version": 3,
  "name": "Lapidary — Save Gemini Chats to Drive",
  "version": "1.0.0",
  "description": "Save Gemini conversations to Google Drive as Markdown files.",
  "permissions": [
    "identity",
    "storage"
  ],
  "host_permissions": [
    "https://gemini.google.com/*",
    "https://www.googleapis.com/drive/*",
    "https://www.googleapis.com/upload/drive/*",
    "https://www.googleapis.com/oauth2/*",
    "https://oauth2.googleapis.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": [
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "oauth2": {
    "client_id": "836492783360-6h1qfdb1gveu38luiknn7jsp4hddpsml.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.file",
      "https://www.googleapis.com/auth/userinfo.email"
    ]
  }
}